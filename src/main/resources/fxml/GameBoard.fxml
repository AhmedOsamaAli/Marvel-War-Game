<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.marvelwargame.ui.controllers.GameBoardController"
            styleClass="scene-background"
            stylesheets="@../css/marvel-theme.css"
            prefWidth="1200" prefHeight="780">

    <!-- ── Top Bar ─────────────────────────────────────────────────────── -->
    <top>
        <HBox style="-fx-background-color: #0d0d1a; -fx-padding: 10 20 10 20;
                     -fx-border-color: rgba(237,29,36,0.3); -fx-border-width: 0 0 1 0;"
              alignment="CENTER" spacing="0">

            <!-- Player 1 info -->
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER_LEFT" spacing="10">
                <Label fx:id="lblP1Name" text="PLAYER 1" styleClass="body-text player1-color"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <HBox fx:id="p1TeamStatus" spacing="5"/>
            </HBox>

            <!-- Center turn info -->
            <VBox alignment="CENTER" spacing="2" minWidth="320">
                <Label fx:id="lblTurnInfo" text="TURN 1" styleClass="section-title"
                       style="-fx-font-size: 13px;"/>
                <Label fx:id="lblCurrentChampion" text="Captain America's Turn"
                       styleClass="body-text" style="-fx-text-fill: -text-gold; -fx-font-size: 12px;"/>
            </VBox>

            <!-- Player 2 info -->
            <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" spacing="10">
                <ToggleButton fx:id="btnMute" text="&#x1F50A;" styleClass="btn-mute"
                              onAction="#onMuteToggle" />
                <HBox fx:id="p2TeamStatus" spacing="5"/>
                <Label fx:id="lblP2Name" text="PLAYER 2" styleClass="body-text player2-color"
                       style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
            </HBox>
        </HBox>
    </top>

    <!-- ── Left Panel ──────────────────────────────────────────────────── -->
    <left>
        <VBox fx:id="leftPanel" styleClass="side-panel"
              style="-fx-padding: 16; -fx-spacing: 12;" minWidth="190" maxWidth="190">
            <Label text="CURRENT CHAMPION" styleClass="section-title"
                   style="-fx-font-size: 13px;"/>

            <!-- Portrait placeholder -->
            <StackPane fx:id="portraitPane" style="-fx-min-height: 160; -fx-max-height: 160;
                        -fx-border-color: rgba(237,29,36,0.5); -fx-border-width: 1;
                        -fx-background-radius: 6; -fx-border-radius: 6;" />

            <!-- Name + type -->
            <Label fx:id="lblChampName" text="Champion Name"
                   styleClass="card-name" style="-fx-font-size: 15px;"/>
            <Label fx:id="lblChampType" text="Hero" styleClass="card-type-badge badge-hero"/>

            <!-- HP Bar -->
            <VBox spacing="2">
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="HP" styleClass="dim-text"/>
                    <Label fx:id="lblHpValue" text="1500/1500" styleClass="stat-hp"
                           style="-fx-font-size: 11px;"/>
                </HBox>
                <ProgressBar fx:id="hpBar" styleClass="hp-bar" maxWidth="Infinity" prefHeight="8"/>
            </VBox>

            <!-- Mana Bar -->
            <VBox spacing="2">
                <HBox alignment="CENTER_LEFT" spacing="4">
                    <Label text="MANA" styleClass="dim-text"/>
                    <Label fx:id="lblManaValue" text="1000/1000" styleClass="stat-mana"
                           style="-fx-font-size: 11px;"/>
                </HBox>
                <ProgressBar fx:id="manaBar" styleClass="mana-bar" maxWidth="Infinity" prefHeight="8"/>
            </VBox>

            <!-- Action Points -->
            <HBox spacing="4" alignment="CENTER_LEFT">
                <Label text="AP" styleClass="dim-text"/>
                <HBox fx:id="apPips" spacing="3"/>
            </HBox>

            <!-- Stats -->
            <GridPane hgap="8" vgap="4">
                <Label text="SPD:" styleClass="dim-text" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <Label fx:id="lblSpeed" text="80" styleClass="stat-spd"
                       GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <Label text="ATK:" styleClass="dim-text" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                <Label fx:id="lblAtk" text="100" styleClass="stat-atk"
                       GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                <Label text="RNG:" styleClass="dim-text" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <Label fx:id="lblRange" text="1" styleClass="body-text"
                       GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            </GridPane>

            <!-- Active Effects -->
            <Label text="EFFECTS" styleClass="dim-text" style="-fx-font-size: 10px;"/>
            <FlowPane fx:id="effectsPane" hgap="4" vgap="4"/>

            <Region VBox.vgrow="ALWAYS"/>

            <!-- Leader ability button -->
            <Button fx:id="btnLeader" text="★ LEADER ABILITY"
                    styleClass="btn-secondary"
                    maxWidth="Infinity" onAction="#onLeaderAbility"/>
        </VBox>
    </left>

    <!-- ── Center - Game Board ─────────────────────────────────────────── -->
    <center>
        <VBox alignment="CENTER" spacing="0">
            <!-- Player 2 label (top) -->
            <Label fx:id="lblP2BoardName" text="► PLAYER 2 ◄"
                   styleClass="body-text player2-color"
                   style="-fx-padding: 8 0 4 0;"/>

            <!-- Board grid -->
            <StackPane>
                <GridPane fx:id="boardGrid" styleClass="board-grid"
                          alignment="CENTER" hgap="5" vgap="5"/>

                <!-- Turn Announcement Banner -->
                <StackPane fx:id="turnBannerPane" visible="false" mouseTransparent="true"
                           styleClass="turn-banner-pane"
                           StackPane.alignment="TOP_CENTER"
                           prefHeight="56" maxHeight="56">
                    <VBox alignment="CENTER" spacing="2">
                        <Label fx:id="lblTurnBanner" text="CHAMPION'S TURN"
                               styleClass="turn-banner-text" style="-fx-text-fill: white;"/>
                        <Label fx:id="lblTurnBannerSub" text="START OF TURN"
                               styleClass="turn-banner-sub"/>
                    </VBox>
                </StackPane>

                <!-- Game-over overlay -->
                <StackPane fx:id="gameOverOverlay" visible="false"
                           styleClass="game-over-overlay">
                    <VBox alignment="CENTER" spacing="20">
                        <Label text="GAME OVER" styleClass="game-over-title"/>
                        <Label fx:id="lblWinner" text="Player 1 Wins!"
                               styleClass="game-over-winner"/>
                        <HBox spacing="16" alignment="CENTER">
                            <Button text="PLAY AGAIN" styleClass="btn-primary"
                                    prefWidth="160" onAction="#onPlayAgain"/>
                            <Button text="MAIN MENU" styleClass="btn-secondary"
                                    prefWidth="160" onAction="#onMainMenu"/>
                        </HBox>
                    </VBox>
                </StackPane>
            </StackPane>

            <!-- Player 1 label (bottom) -->
            <Label fx:id="lblP1BoardName" text="► PLAYER 1 ◄"
                   styleClass="body-text player1-color"
                   style="-fx-padding: 4 0 8 0;"/>
        </VBox>
    </center>

    <!-- ── Right Panel ─────────────────────────────────────────────────── -->
    <right>
        <VBox style="-fx-background-color: #16213e; -fx-padding: 16; -fx-spacing: 10;
                     -fx-border-color: rgba(237,29,36,0.25); -fx-border-width: 0 0 0 1;"
              minWidth="220" maxWidth="220">

            <Label text="ABILITIES" styleClass="section-title" style="-fx-font-size: 13px;"/>

            <!-- Ability Cards Container -->
            <VBox fx:id="abilitiesBox" spacing="8"/>

            <!-- Cast Now button — visible only for auto-cast abilities (SURROUND/TEAM/SELF) -->
            <Button fx:id="btnCastNow" text="⚡ CAST NOW"
                    styleClass="btn-cast-now" maxWidth="Infinity"
                    onAction="#onCastNow"
                    visible="false" managed="false"/>

            <Region VBox.vgrow="ALWAYS"/>

            <Label text="ACTIONS" styleClass="section-title" style="-fx-font-size: 13px;"/>

            <!-- Direction D-pad with icons -->
            <Label text="DIRECTION" styleClass="dim-text" style="-fx-font-size: 10px; -fx-letter-spacing: 2px;"/>
            <GridPane alignment="CENTER" hgap="5" vgap="5">
                <Button fx:id="btnDirUp" styleClass="btn-icon" onAction="#onDirectionUp"
                        GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="52" prefHeight="52"/>
                <Button fx:id="btnDirLeft" styleClass="btn-icon" onAction="#onDirectionLeft"
                        GridPane.columnIndex="0" GridPane.rowIndex="1" prefWidth="52" prefHeight="52"/>
                <Button fx:id="btnDirDown" styleClass="btn-icon" onAction="#onDirectionDown"
                        GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="52" prefHeight="52"/>
                <Button fx:id="btnDirRight" styleClass="btn-icon" onAction="#onDirectionRight"
                        GridPane.columnIndex="2" GridPane.rowIndex="1" prefWidth="52" prefHeight="52"/>
            </GridPane>

            <!-- Action mode tab strip (replaces radio buttons) -->
            <VBox spacing="5" style="-fx-padding: 6 0 0 0;">
                <fx:define>
                    <ToggleGroup fx:id="actionModeGroup"/>
                </fx:define>
                <Label text="ACTION MODE" styleClass="dim-text" style="-fx-font-size: 10px; -fx-letter-spacing: 2px;"/>
                <HBox styleClass="action-tab-strip" spacing="0">
                    <ToggleButton fx:id="tbMove" text="MOVE" styleClass="action-tab"
                                  selected="true" toggleGroup="$actionModeGroup"/>
                    <ToggleButton fx:id="tbAttack" text="ATTACK" styleClass="action-tab"
                                  toggleGroup="$actionModeGroup"/>
                    <ToggleButton fx:id="tbCast" text="CAST" styleClass="action-tab"
                                  toggleGroup="$actionModeGroup"/>
                </HBox>
                <Label fx:id="lblActionHint" text="Select direction above or click a cell"
                       styleClass="dim-text" style="-fx-font-size: 9px;" wrapText="true"/>
            </VBox>

            <Button fx:id="btnEndTurn" text="END TURN  →"
                    styleClass="btn-end-turn" maxWidth="Infinity"
                    onAction="#onEndTurn" style="-fx-margin-top: 10;"/>
        </VBox>
    </right>

    <!-- ── Bottom Log ───────────────────────────────────────────────────── -->
    <bottom>
        <VBox styleClass="log-pane" prefHeight="100" maxHeight="100">
            <TextArea fx:id="gameLog" styleClass="log-text-area"
                      editable="false" wrapText="true"
                      maxHeight="Infinity" VBox.vgrow="ALWAYS"/>
        </VBox>
    </bottom>

</BorderPane>
